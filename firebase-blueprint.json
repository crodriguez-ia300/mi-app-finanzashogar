{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense).",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the transaction." },
        "title": { "type": "string", "description": "Title or note for the transaction." },
        "category": { "type": "string", "description": "Category of the transaction (e.g., Súper, Comida, Ingresos)." },
        "amount": { "type": "number", "description": "The amount of the transaction." },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Type of transaction." },
        "date": { "type": "string", "format": "date-time", "description": "ISO 8601 date string." },
        "icon": { "type": "string", "description": "Icon name for the transaction." },
        "uid": { "type": "string", "description": "The UID of the user who owns this transaction." }
      },
      "required": ["id", "title", "category", "amount", "type", "date", "icon", "uid"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The UID of the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile photo." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role." }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's financial transactions."
    }
  }
}
